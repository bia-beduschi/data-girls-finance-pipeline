# .env.example — template de variáveis de ambiente.
#
# Copie este arquivo para ".env" e preencha com suas credenciais REAIS:
#   cp .env.example .env
#
# O arquivo ".env" (sem o ".example") NUNCA deve ser commitado no Git —
# ele já está protegido pelo .gitignore. Este arquivo aqui (.env.example)
# é só um modelo/template e deve conter apenas placeholders, nunca
# credenciais de verdade.

# Credenciais da API do Kaggle (kaggle.com -> Account -> API -> Create New Token)
KAGGLE_USERNAME=seu_usuario_kaggle
KAGGLE_KEY=sua_chave_kaggle

# Credenciais AWS IAM (com permissão restrita ao bucket do projeto)
AWS_ACCESS_KEY_ID=sua_access_key_aws
AWS_SECRET_ACCESS_KEY=sua_secret_key_aws
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=seu_bucket_s3

# UID do usuário local, usado pelo Docker Compose do Airflow (Linux/Mac).
# No Windows, pode manter o valor padrão abaixo.
AIRFLOW_UID=50000